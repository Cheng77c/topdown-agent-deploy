# TopDown Agent — customer config. Copy to .env and fill LLM_API_KEY + WORKSPACES_DIR.

# Our private registry (already set; don't change unless told to).
# Self-signed — trust ca.crt first (see README §1).
REGISTRY=hgmz1471486.bohrium.tech:50001
TAG=dev

# LLM key (required).
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Your data area (recommended). Mount one host folder that CONTAINS your .mzML/.raw
# inputs; you then pick sub-folders inside it as the per-conversation workspace, and
# analysis products land right next to your data. Inputs, products and the
# visualization bundles all live here (one read-write mount).
#   - Point it at the common parent of your datasets, e.g. /Users/me/proteomics
#   - If your data is scattered, mount the parent that holds them all.
#   - Default below creates a ./workspaces folder next to this file.
# NOTE: on macOS/Windows, Docker Desktop bind mounts are slower than Linux (the
# files live outside the Linux VM and every read is translated). For heavy runs,
# prefer a Linux host. Keep the path absolute on Mac/Windows.
WORKSPACES_DIR=./workspaces

# Optional — keep ports as-is (chat-ui has the agent URL baked as localhost:50001).
# PUBLIC_HOST=localhost
# AGENT_PORT=50001
# CHATUI_PORT=3000
# VIEWER_PORT=7390
# POSTGRES_PASSWORD=...   # internal only, not exposed; default is fine
